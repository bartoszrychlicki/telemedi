generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  COORDINATOR
  HR_STAFF
}

enum HazardCategory {
  PHYSICAL
  CHEMICAL
  BIOLOGICAL
  DUST
  OTHER
}

enum ReferralType {
  INITIAL
  PERIODIC
  CONTROL
}

enum ReferralStatus {
  DRAFT
  SUBMITTED
  SCHEDULED
  COMPLETED
  CLOSED
  CANCELLED
}

enum ReferralAttentionReason {
  NONE
  NEEDS_CORRECTION
  EMPLOYEE_UNREACHABLE
  RESCHEDULE_REQUIRED
  NO_SHOW
  NEGATIVE_DECISION
}

enum EmploymentContext {
  EMPLOYED
  STARTING_WORK
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appRole   UserRole @default(HR_STAFF)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  sessions         Session[]
  accounts         Account[]
  members          Member[]
  invitationsSent  Invitation[] @relation("InvitationInviter")
  referralsCreated Referral[]
  statusEvents     ReferralStatusEvent[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?
  activeTeamId         String?

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Organization {
  id        String   @id
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime

  companies   Company[]
  members     Member[]
  invitations Invitation[]
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@unique([organizationId, userId])
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  teamId         String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  inviter        User         @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([inviterId])
}

model Company {
  id           String   @id @default(cuid())
  name         String
  shortName    String?
  nip          String
  regon        String
  address      String
  contactPhone String?
  contactEmail String?
  pdfIssuedPlace String?
  pdfSignatoryName String?
  pdfSignatoryTitle String?
  pdfFooterNote String?
  orgId        String   @unique
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  employees   Employee[]
  hazards     HazardFactor[]
  templates   Template[]
  referrals   Referral[]
}

model Employee {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firstName               String
  lastName                String
  pesel                   String?
  birthDate               DateTime?
  identityDocumentSeries  String?
  identityDocumentNumber  String?
  identityDocumentName    String?
  identityDocumentCountry String?
  position                String
  address                 String
  email                   String
  phone                   String
  archivedAt              DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  referrals Referral[]

  @@index([companyId, archivedAt])
  @@index([companyId, lastName])
  @@unique([companyId, email])
}

model HazardFactor {
  id        String         @id @default(cuid())
  category  HazardCategory
  name      String
  isSystem  Boolean        @default(false)
  companyId String?
  company   Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  templateHazards TemplateHazard[]
  referralHazards ReferralHazard[]

  @@index([companyId, category])
  @@index([isSystem, category])
  @@unique([companyId, category, name])
}

model Template {
  id                  String   @id @default(cuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                String
  positionDescription String?
  workDescription     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  hazardFactors TemplateHazard[]

  @@index([companyId])
  @@unique([companyId, name])
}

model TemplateHazard {
  templateId     String
  hazardFactorId String
  template       Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  hazardFactor   HazardFactor @relation(fields: [hazardFactorId], references: [id], onDelete: Cascade)

  defaultExposureValue     String?
  defaultMeasurementResult String?

  @@id([templateId, hazardFactorId])
}

model Referral {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  type            ReferralType
  status          ReferralStatus          @default(DRAFT)
  attentionReason ReferralAttentionReason @default(NONE)

  employeeNameSnapshot             String
  employeePeselSnapshot            String?
  employeeBirthDateSnapshot        DateTime?
  employeeIdentityDocumentSnapshot String?
  employeeAddressSnapshot          String
  employmentContext                EmploymentContext
  positionSnapshot                 String
  positionDescription              String
  workDescription                  String
  issuedPlace                      String
  deadlineDate                     DateTime
  issuedAt                         DateTime @default(now())

  facilityName    String?
  appointmentDate DateTime?

  occupationalMedicineCertificateRef String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)

  hazardFactors ReferralHazard[]
  statusEvents  ReferralStatusEvent[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, deadlineDate])
  @@index([employeeId])
}

model ReferralHazard {
  id             String        @id @default(cuid())
  referralId     String
  referral       Referral      @relation(fields: [referralId], references: [id], onDelete: Cascade)
  hazardFactorId String?
  hazardFactor   HazardFactor? @relation(fields: [hazardFactorId], references: [id], onDelete: SetNull)

  category           HazardCategory
  factorNameSnapshot String
  exposureValue      String
  measurementResult  String?
  notes              String?

  @@index([referralId])
}

model ReferralStatusEvent {
  id              String                   @id @default(cuid())
  referralId      String
  referral        Referral                 @relation(fields: [referralId], references: [id], onDelete: Cascade)
  fromStatus      ReferralStatus?
  toStatus        ReferralStatus
  attentionReason ReferralAttentionReason?
  facilityName    String?
  appointmentDate DateTime?
  note            String?
  createdById     String?
  createdBy       User?                    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime                 @default(now())

  @@index([referralId, createdAt])
}
